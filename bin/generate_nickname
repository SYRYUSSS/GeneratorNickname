#!/usr/bin/env ruby

require_relative '../lib/nickname_generator'
require_relative '../lib/animator'
require 'optparse'

options = {}
opt_parser = OptionParser.new do |opts|
  opts.banner = "Usage: generate_nickname [options]"

  opts.on("--type TYPE", [:random, :from_name, :gamer], "Type: random, from_name, gamer") do |t|
    options[:type] = t
  end

  opts.on("--name NAME", "Base name for from_name/gamer") do |n|
    options[:name] = n
  end

  opts.on("--[no-]prefix", "Include prefix (default true)") do |p|
    options[:prefix] = p
  end

  opts.on("--[no-]suffix", "Include suffix") do |s|
    options[:suffix] = s
  end

  opts.on("--[no-]leet", "Apply leet (for gamer)") do |l|
    options[:leet] = l
  end

  opts.on("--[no-]number", "Include number") do |n|
    options[:number] = n
  end

  opts.on("--separator SEP", "Separator (default '_')") do |sep|
    options[:separator] = sep
  end

  opts.on("--wrap-x", "Wrap with xX _ Xx (gamer style)") do
    options[:wrap_with_x] = true
  end

  opts.on("--anim STYLE", [:typewriter, :wave, :blink, :fade, :slide, :bounce, :rainbow, :matrix, :none],
          "Animation style: typewriter, wave, blink, fade, slide, bounce, rainbow, matrix, none") do |a|
    options[:animation] = a
  end

  opts.on("--delay SECONDS", Float, "Delay between frames in seconds (default 0.05)") do |d|
    options[:delay] = d
  end

  opts.on("-h", "--help", "Prints help") do
    puts opts
    exit
  end
end

opt_parser.parse!

# Выбор стратегии на основе параметров
strategy = case options[:type]
           when :from_name then FromNameStrategy.new
           when :gamer then GamerStrategy.new
           else RandomStrategy.new
           end

# Инициализация контекста со выбранной стратегией
generator = NicknameGenerator.new(strategy)

# Генерация ника
result = generator.generate(options)

# Анимация (по умолчанию без анимации)
animation_style = options[:animation] || :none
delay = options[:delay] || 0.05
Animator.animate(result, animation_style, delay)